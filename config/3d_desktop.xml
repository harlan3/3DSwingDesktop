<?xml version='1.0' encoding='UTF-8'?>
<javaDesktop>
   <!-- Use 3 desktops below to include the desktop containing Win32 native applications. -->
   <!-- Desktop 3 is slow coming up, so we default to only 2 desktops. -->
   <numberDesktops>2</numberDesktops>
   <desktop1>
       <desktopWindowType>Swing</desktopWindowType>
       <animSupport>yes</animSupport>
       <javaWindowsApp>
       	  <windowIndex>1</windowIndex>
          <projectionShape>windowPlaneLeft</projectionShape>
          <width>800</width>
          <height>400</height>
          <x>10</x>
          <y>0</y>
          <size>0.85</size>
          <tilt>65</tilt>
          <jarFile>SwingPaint.jar</jarFile>
       </javaWindowsApp>
       <javaWindowsApp>
       	  <windowIndex>2</windowIndex>
          <projectionShape>windowPlaneLeft</projectionShape>
          <width>800</width>
          <height>400</height>
          <x>10</x>
          <y>375</y>
          <size>0.85</size>
          <tilt>65</tilt>
          <jarFile>SwingCodeEditor.jar</jarFile>
       </javaWindowsApp>
       <javaWindowsApp>
       	  <windowIndex>3</windowIndex>
          <projectionShape>windowPlaneLeft</projectionShape>
          <width>800</width>
          <height>400</height>
          <x>10</x>
          <y>750</y>
          <size>0.85</size>
          <tilt>65</tilt>
          <jarFile>HelloWorld3Frame.jar</jarFile>
       </javaWindowsApp>
       <javaWindowsApp>
       	  <windowIndex>4</windowIndex>
          <projectionShape>cube</projectionShape>
          <width>1310</width>
          <height>800</height>
          <x>600</x>
          <y>-50</y>
          <size>0.9</size>
          <jarFile>HelloWorld5Frame.jar</jarFile>
          <jarFile>WayOfTheDragon_clip.jar</jarFile>
          <jarFile>HelloWorld6Frame.jar</jarFile>
          <jarFile>HelloWorld7Frame.jar</jarFile>
          <jarFile>HelloWorld8Frame.jar</jarFile>
          <jarFile>HelloWorld9Frame.jar</jarFile>
       </javaWindowsApp>
       <javaWindowsApp>
       	  <windowIndex>5</windowIndex>
       	  <applicationType>Swing</applicationType>
          <projectionShape>windowPlaneRight</projectionShape>
          <width>800</width>
          <height>400</height>
          <x>1120</x>
          <y>700</y>
          <size>0.85</size>
          <tilt>65</tilt>
          <jarFile>SwingDiffTool.jar</jarFile>
       </javaWindowsApp>
   </desktop1>
   <desktop2>
       <desktopWindowType>SWT</desktopWindowType>
       <animSupport>no</animSupport>
       <javaWindowsApp>
       	  <windowIndex>2</windowIndex>
          <projectionShape>na</projectionShape>
          <width>1920</width>
          <height>1200</height>
          <x>0</x>
          <y>0</y>
          <size>1.0</size>
          <javaClassName>orbisoftware.SwingSwtBrowser</javaClassName>
       </javaWindowsApp>
   </desktop2>
   <desktop3>
       <desktopWindowType>Win32</desktopWindowType>
       <animSupport>no</animSupport>
       <javaWindowsApp>
       	   <windowIndex>1</windowIndex>
           <projectionShape>na</projectionShape>
           <width>335</width>
           <height>525</height>
           <x>0</x>
           <y>0</y>
          <size>1.0</size>
           <javaClassName>orbisoftware.Calculator</javaClassName>
       </javaWindowsApp>
       <javaWindowsApp>
       	   <windowIndex>2</windowIndex>
           <projectionShape>na</projectionShape>
           <animSupport>no</animSupport>
           <fallbackImage>file1.png</fallbackImage>
           <width>1008</width>
           <height>630</height>
           <x>0</x>
           <y>525</y>
          <size>1.0</size>
           <javaClassName>orbisoftware.Command</javaClassName>
       </javaWindowsApp>
       <javaWindowsApp>
       	   <windowIndex>3</windowIndex>
           <projectionShape>na</projectionShape>
           <width>1008</width>
           <height>625</height>
           <x>1000</x>
           <y>525</y>
          <size>1.0</size>
           <javaClassName>orbisoftware.FileExplorer</javaClassName>
       </javaWindowsApp>
       <javaWindowsApp>
       	   <windowIndex>4</windowIndex>
           <projectionShape>na</projectionShape>
           <width>1075</width>
           <height>525</height>
           <x>595</x>
           <y>0</y>
          <size>1.0</size>
           <javaClassName>orbisoftware.Notepad</javaClassName>
       </javaWindowsApp>
   </desktop3>
</javaDesktop>
